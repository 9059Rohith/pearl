{
  "name": "@publication/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main",
    "lint": "corepack pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "corepack pnpm exec jest --config ./jest.config.js",
    "test:watch": "corepack pnpm exec jest --watch --config ./jest.config.js",
    "test:coverage": "corepack pnpm exec jest --coverage --config ./jest.config.js",
    "db:generate": "corepack pnpm exec prisma generate",
    "db:push": "corepack pnpm exec prisma db push",
    "db:migrate": "corepack pnpm exec prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@prisma/client": "^6.6.0",
    "@publication/shared": "workspace:*",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.7",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.2.6",
    "typescript": "^5.4.0"
  }
}
